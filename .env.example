# ── Amadeus API (https://developers.amadeus.com) ──────────────────────────────
# Create a free account, create an app, copy the keys from the "Production" tab.
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
AMADEUS_HOSTNAME=production

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# 1. Open Telegram, search @BotFather, send /newbot, follow prompts → get token
# 2. Start a chat with your new bot (search its username and press Start)
# 3. Visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates to find your chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram numeric chat ID (see step 3 above)
TELEGRAM_CHAT_ID_YULIIA=your_chat_id_here

# Ivan's Telegram numeric chat ID (he must also start a chat with the bot first)
TELEGRAM_CHAT_ID_IVAN=ivans_chat_id_here
